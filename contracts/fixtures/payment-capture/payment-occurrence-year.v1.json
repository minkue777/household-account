{
  "schemaVersion": 1,
  "policy": "payment-occurrence-year",
  "cases": [
    {
      "caseId": "year-boundary-december-rolls-back",
      "requirementIds": [
        "T-PARSE-003"
      ],
      "description": "1월에 수신한 12월 결제는 전년을 선택한다",
      "input": {
        "month": 12,
        "day": 31,
        "hour": 23,
        "minute": 59,
        "receivedAt": "2026-01-01T00:05:00+09:00",
        "zoneId": "Asia/Seoul"
      },
      "expected": {
        "kind": "success",
        "occurredLocalDateTime": "2025-12-31T23:59"
      }
    },
    {
      "caseId": "same-day-future-minute-rolls-back",
      "requirementIds": [
        "T-PARSE-003"
      ],
      "description": "같은 날짜라도 수신 시각보다 1분 미래이면 전년을 선택한다",
      "input": {
        "month": 7,
        "day": 19,
        "hour": 10,
        "minute": 1,
        "receivedAt": "2026-07-19T10:00:00+09:00",
        "zoneId": "Asia/Seoul"
      },
      "expected": {
        "kind": "success",
        "occurredLocalDateTime": "2025-07-19T10:01"
      }
    },
    {
      "caseId": "exact-received-minute-keeps-current-year",
      "requirementIds": [
        "T-PARSE-003"
      ],
      "description": "수신 시각과 정확히 같으면 현재 연도를 유지한다",
      "input": {
        "month": 7,
        "day": 19,
        "hour": 10,
        "minute": 0,
        "receivedAt": "2026-07-19T10:00:00+09:00",
        "zoneId": "Asia/Seoul"
      },
      "expected": {
        "kind": "success",
        "occurredLocalDateTime": "2026-07-19T10:00"
      }
    },
    {
      "caseId": "past-month-keeps-current-year",
      "requirementIds": [
        "T-PARSE-003"
      ],
      "description": "12월에 수신한 지난 1월 결제는 현재 연도를 유지한다",
      "input": {
        "month": 1,
        "day": 1,
        "hour": 0,
        "minute": 0,
        "receivedAt": "2026-12-31T23:59:00+09:00",
        "zoneId": "Asia/Seoul"
      },
      "expected": {
        "kind": "success",
        "occurredLocalDateTime": "2026-01-01T00:00"
      }
    },
    {
      "caseId": "leap-day-finds-nearest-valid-year",
      "requirementIds": [
        "T-PARSE-003"
      ],
      "description": "현재 연도에 없는 2월 29일은 가장 가까운 과거 윤년을 선택한다",
      "input": {
        "month": 2,
        "day": 29,
        "hour": 9,
        "minute": 30,
        "receivedAt": "2025-03-01T00:00:00+09:00",
        "zoneId": "Asia/Seoul"
      },
      "expected": {
        "kind": "success",
        "occurredLocalDateTime": "2024-02-29T09:30"
      }
    },
