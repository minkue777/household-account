{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://household-account.local/schemas/system/household-query.v1.schema.json",
  "title": "Household Query V1",
  "description": "인증된 Firebase callable 경계로 전달하는 공통 Query envelope입니다. Actor와 가구 접근 권한은 서버가 인증 정보와 Membership에서 판정합니다.",
  "type": "object",
  "additionalProperties": false,
  "required": ["contractVersion", "queryId", "householdId", "query", "payload"],
  "properties": {
    "contractVersion": { "const": "household-query.v1" },
    "queryId": { "$ref": "#/$defs/stableId" },
    "householdId": { "$ref": "#/$defs/stableId" },
    "query": {
      "type": "string",
      "minLength": 5,
      "maxLength": 120,
      "pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z][a-z0-9-]*)+\\.v[1-9][0-9]*$"
    },
    "payload": { "type": "object" }
  },
  "$defs": {
    "stableId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    }
  }
}
