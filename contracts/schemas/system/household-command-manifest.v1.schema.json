{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://household-account.local/schemas/system/household-command-manifest.v1.schema.json",
  "title": "Household Command Manifest V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contractVersion", "commands"],
  "properties": {
    "contractVersion": { "const": "household-command-manifest.v1" },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "owner", "scope", "clients"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*(?:\\.[a-z][a-z0-9-]*)+\\.v[1-9][0-9]*$"
          },
          "owner": {
            "enum": [
              "access",
              "household-finance.ledger",
              "household-finance.categories-budget",
              "household-finance.recurring",
              "payment-capture.configuration",
              "payment-capture.shortcut-ingestion",
              "portfolio.core",
              "portfolio.holdings",
              "notifications",
              "home-preferences"
            ]
          },
          "scope": { "enum": ["principal", "household"] },
          "clients": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "enum": ["web", "android"] }
          }
        }
      }
    }
  }
}
