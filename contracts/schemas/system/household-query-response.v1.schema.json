{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://household-account.local/schemas/system/household-query-response.v1.schema.json",
  "title": "Household Query Response V1",
  "description": "공통 Query callable의 정규 transport 결과입니다.",
  "type": "object",
  "additionalProperties": false,
  "required": ["contractVersion", "queryId", "result"],
  "properties": {
    "contractVersion": { "const": "household-query-response.v1" },
    "queryId": { "$ref": "#/$defs/stableId" },
    "result": {
      "oneOf": [
        { "$ref": "#/$defs/succeeded" },
        { "$ref": "#/$defs/alreadyProcessed" },
        { "$ref": "#/$defs/rejected" }
      ]
    }
  },
  "$defs": {
    "stableId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "succeeded": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value"],
      "properties": { "kind": { "const": "succeeded" }, "value": {} }
    },
    "alreadyProcessed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "value"],
      "properties": { "kind": { "const": "already-processed" }, "value": {} }
    },
    "rejected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "error"],
      "properties": {
        "kind": { "const": "rejected" },
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "retryable"],
          "properties": {
            "code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]{1,79}$" },
            "retryable": { "type": "boolean" }
          }
        }
      }
    }
  }
}
