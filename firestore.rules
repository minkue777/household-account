rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSystemAdministrator() {
      return signedIn() && request.auth.token.systemAdmin == true;
    }

    function activeMembership(householdId) {
      return signedIn()
        && exists(/databases/$(database)/documents/households/$(householdId)/memberships/$(request.auth.uid))
        && get(/databases/$(database)/documents/households/$(householdId)/memberships/$(request.auth.uid)).data.lifecycleState == 'active';
    }

    function canReadLegacyHouseholdDocument() {
      return resource.data.householdId is string
        && activeMembership(resource.data.householdId);
    }

    // Firebase Admin SDK를 사용하는 Functions만 Canonical 데이터를 씁니다.
    // Client SDK의 write는 명시적인 예외가 없으면 모두 거부합니다.

    match /users/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if false;

      match /householdMembershipViews/{householdId} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow write: if false;
      }
    }

    match /households/{householdId} {
      allow read: if activeMembership(householdId);
      allow write: if false;

      match /members/{memberId} {
        allow read: if activeMembership(householdId);
        allow write: if false;
      }

      match /memberships/{principalUid} {
        allow read: if signedIn()
          && request.auth.uid == principalUid
          && activeMembership(householdId);
        allow write: if false;
      }

      match /assetOwnerProfiles/{profileId} {
        allow read: if activeMembership(householdId);
        allow write: if false;
      }

      match /categories/{categoryId} {
        allow read: if activeMembership(householdId);
        allow write: if false;
      }

      match /categorySettings/{settingId} {
        allow read: if activeMembership(householdId);
        allow write: if false;
      }

      match /ledgerTransactions/{transactionId} {
        allow read: if activeMembership(householdId);
        allow write: if false;
      }

      match /recurringPlans/{planId} {
        allow read: if activeMembership(householdId);
        allow write: if false;
      }

      match /localCurrencyBalances/{currencyType} {
        allow read: if activeMembership(householdId);
        allow write: if false;
      }

      match /registeredCards/{cardId} {
        allow read: if activeMembership(householdId);
        allow write: if false;
      }

      match /merchantRules/{ruleId} {
        allow read: if activeMembership(householdId);
        allow write: if false;
      }

      match /assets/{assetId} {
        allow read: if activeMembership(householdId);
        allow write: if false;

        match /positions/{positionId} {
          allow read: if activeMembership(householdId);
          allow write: if false;
        }

        match /positionHistory/{snapshotId} {
          allow read: if activeMembership(householdId);
          allow write: if false;
        }
      }

      match /assetSnapshots/{localDate} {
        allow read: if activeMembership(householdId);
        allow write: if false;
      }

      match /dividendEvents/{eventId} {
        allow read: if activeMembership(householdId);
        allow write: if false;
      }

      match /dividendAnnualViews/{year} {
        allow read: if activeMembership(householdId);
        allow write: if false;
      }

      match /homePreferences/{scopeId} {
        allow read: if activeMembership(householdId);
        allow write: if false;
      }

      // Membership claim, receipt, Outbox, delivery와 운영 상태는 client 비공개입니다.
      match /{serverOnlyCollection}/{document=**} {
        allow read, write: if false;
      }
    }

    // V2 전환 기간에 기존 flat collection을 읽는 호환 경계입니다.
    // householdId 조건 없는 query와 모든 client write는 거부됩니다.
    match /{legacyCollection}/{documentId} {
      allow read: if legacyCollection in [
          'expenses',
          'categories',
          'merchant_rules',
          'registered_cards',
          'recurring_expenses',
          'budgetTransfers',
          'balances',
          'assets',
          'asset_history',
          'stock_holdings',
          'crypto_holdings',
          'asset_snapshots',
          'dividend_snapshots',
          'dividend_events'
        ]
        && canReadLegacyHouseholdDocument();
      allow write: if false;
    }

    match /householdInvitations/{invitationHash} {
      allow read, write: if false;
    }

    match /legacyMembershipClaims/{claimKeyHash} {
      allow read, write: if false;
    }

    match /principalMembershipClaims/{claimId} {
      allow read, write: if false;
    }

    match /notificationEndpoints/{endpointId} {
      allow read, write: if false;
    }

    match /commandReceipts/{document=**} {
      allow read, write: if false;
    }

    match /inboxReceipts/{document=**} {
      allow read, write: if false;
    }

    match /operations/{document=**} {
      allow read: if isSystemAdministrator();
      allow write: if false;
    }

    match /marketData/{document=**} {
      allow read, write: if false;
    }

    match /fcmTokens/{tokenId} {
      allow read, write: if false;
    }

    match /notification_debug_logs/{logId} {
      allow read: if isSystemAdministrator();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
